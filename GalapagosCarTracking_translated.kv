<Cargo>:
    name: "Cargo"
    FloatLayout:
        canvas.before:
            Color:
                rgba: 0.98, 0.98, 0.98, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # Language Toggle
        Button:
            size_hint: (None, None)
            size: ('53dp', '53dp')
            pos_hint: {'right': 0.95, 'top': 0.97}
            background_normal: ''
            background_color: 1, 1, 1, 1
            text: app.language_button_text
            font_size: '28sp'
            color: 0.2, 0.2, 0.2, 1
            canvas.before:
                Color:
                    rgba: 0.9, 0.9, 0.9, 1
                Ellipse:
                    pos: self.pos
                    size: self.size
            on_release: app.toggle_language()

        # Back Button
        Button:
            text: '←'
            font_name: 'CaviarDreams_Bold.ttf'
            font_size: '28sp'
            size_hint: (None, None)
            size: ('60dp', '60dp')
            pos_hint: {'x': 0.05, 'top': 0.97}
            background_normal: ''
            background_color: 0, 0, 0, 0
            color: 0.2, 0.2, 0.2, 1
            on_release:
                root.clearPassengerCount()
                app.root.current = "PassengerCount"
                root.manager.transition.direction = "down"

        BoxLayout:
            orientation: 'vertical'
            padding: ['20dp', '100dp', '20dp', '25dp']
            spacing: '12dp'

            Label:
                text: app.language and app.translator.get_text('what_cargo')
                font_name: 'CaviarDreams_Bold.ttf'
                font_size: '22sp'
                color: 0.1, 0.1, 0.1, 1
                size_hint_y: None
                height: '60dp'
                halign: 'center'
                valign: 'middle'
                text_size: self.width, None

            Widget:
                size_hint_y: None
                height: '6dp'

            # Luggage - Tap to toggle
            Button:
                id: luggage_btn
                text: app.language and app.translator.get_text('luggage')
                font_name: 'CaviarDreams_Bold.ttf'
                font_size: '18sp'
                size_hint_y: None
                height: '62dp'
                background_normal: ''
                background_color: 0.05, 0.05, 0.05, 1
                color: 1, 1, 1, 1
                on_release: root.toggle_cargo('Luggage', 'luggage_btn')

            # Bike
            Button:
                id: bike_btn
                text: app.language and app.translator.get_text('bike')
                font_name: 'CaviarDreams_Bold.ttf'
                font_size: '18sp'
                size_hint_y: None
                height: '62dp'
                background_normal: ''
                background_color: 0.05, 0.05, 0.05, 1
                color: 1, 1, 1, 1
                on_release: root.toggle_cargo('Bike', 'bike_btn')

            # Work Equipment
            Button:
                id: work_btn
                text: app.language and app.translator.get_text('work_equipment')
                font_name: 'CaviarDreams_Bold.ttf'
                font_size: '18sp'
                size_hint_y: None
                height: '62dp'
                background_normal: ''
                background_color: 0.05, 0.05, 0.05, 1
                color: 1, 1, 1, 1
                on_release: root.toggle_cargo('Work Equipment', 'work_btn')

            # Food and Goods
            Button:
                id: food_btn
                text: app.language and app.translator.get_text('food_goods')
                font_name: 'CaviarDreams_Bold.ttf'
                font_size: '18sp'
                size_hint_y: None
                height: '62dp'
                background_normal: ''
                background_color: 0.05, 0.05, 0.05, 1
                color: 1, 1, 1, 1
                on_release: root.toggle_cargo('Food and Goods', 'food_btn')

            # Miscellaneous Cargo
            Button:
                id: misc_btn
                text: app.language and app.translator.get_text('misc_cargo')
                font_name: 'CaviarDreams_Bold.ttf'
                font_size: '18sp'
                size_hint_y: None
                height: '62dp'
                background_normal: ''
                background_color: 0.05, 0.05, 0.05, 1
                color: 1, 1, 1, 1
                on_release: root.toggle_cargo('Miscellaneous Cargo', 'misc_btn')

            Widget:
                size_hint_y: 0.02

            # Next Button
            Button:
                text: app.language and app.translator.get_text('next')
                font_name: 'CaviarDreams_Bold.ttf'
                font_size: '20sp'
                size_hint_y: None
                height: '65dp'
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 0.4, 0.4, 0.4, 1
                canvas.before:
                    Color:
                        rgba: 0.92, 0.92, 0.92, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [12, 12, 12, 12]
                on_release:
                    root.proceed_to_next()

            Widget:
                size_hint_y: 0.02

