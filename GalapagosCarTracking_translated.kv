<TripStats>:
    name: "TripStats"
    FloatLayout:
        canvas.before:
            Color:
                rgba: 0.98, 0.98, 0.98, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # Language Toggle
        Button:
            size_hint: (None, None)
            size: ('50dp', '50dp')
            pos_hint: {'right': 0.95, 'top': 0.97}
            background_normal: ''
            background_color: 1, 1, 1, 1
            text: app.language_button_text
            font_size: '28sp'
            color: 0.2, 0.2, 0.2, 1
            canvas.before:
                Color:
                    rgba: 0.9, 0.9, 0.9, 1
                Ellipse:
                    pos: self.pos
                    size: self.size
            on_release: app.toggle_language()

        # Back Button
        Button:
            text: '←'
            font_name: 'CaviarDreams_Bold.ttf'
            font_size: '26sp'
            size_hint: (None, None)
            size: ('55dp', '55dp')
            pos_hint: {'x': 0.05, 'top': 0.97}
            background_normal: ''
            background_color: 0, 0, 0, 0
            color: 0.2, 0.2, 0.2, 1
            on_release:
                app.root.current = "FinishTrip"
                root.manager.transition.direction = "down"

        ScrollView:
            do_scroll_x: False
            do_scroll_y: True
            scroll_timeout: 250
            scroll_distance: 10
            effect_cls: 'ScrollEffect'

            BoxLayout:
                orientation: 'vertical'
                padding: ['20dp', '80dp', '20dp', '20dp']
                spacing: '10dp'
                size_hint_y: None
                height: self.minimum_height

                Label:
                    text: app.trip_statistics_text
                    font_name: 'CaviarDreams_Bold.ttf'
                    font_size: '20sp'
                    color: 0.1, 0.1, 0.1, 1
                    size_hint_y: None
                    height: '50dp'
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.width, None
                    padding: ['10dp', 0]

                Widget:
                    size_hint_y: None
                    height: '5dp'

                # Compact Stats Card - Auto-sizing height
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    padding: ['12dp', '12dp']
                    spacing: '6dp'
                    canvas.before:
                        Color:
                            rgba: 1, 1, 1, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [12, 12, 12, 12]

                    # Destination
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '30dp'
                        spacing: '8dp'
                        Label:
                            text: app.destination_text
                            font_name: 'CaviarDreams_Bold.ttf'
                            font_size: '13sp'
                            color: 0.4, 0.4, 0.4, 1
                            size_hint_x: 0.4
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size
                        Label:
                            id: Destination
                            text: ''
                            font_name: 'CaviarDreams.ttf'
                            font_size: '14sp'
                            color: 0.1, 0.1, 0.1, 1
                            size_hint_x: 0.6
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size

                    # Passengers & Cargo
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '30dp'
                        spacing: '8dp'
                        Label:
                            text: app.passengers_cargo_text
                            font_name: 'CaviarDreams_Bold.ttf'
                            font_size: '13sp'
                            color: 0.4, 0.4, 0.4, 1
                            size_hint_x: 0.4
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size
                        Label:
                            id: PassengersCargo
                            text: ''
                            font_name: 'CaviarDreams.ttf'
                            font_size: '14sp'
                            color: 0.1, 0.1, 0.1, 1
                            size_hint_x: 0.6
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size

                    Widget:
                        size_hint_y: None
                        height: '3dp'

                    # Distance
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '30dp'
                        spacing: '8dp'
                        Label:
                            text: app.distance_driven_text
                            font_name: 'CaviarDreams_Bold.ttf'
                            font_size: '13sp'
                            color: 0.4, 0.4, 0.4, 1
                            size_hint_x: 0.4
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size
                        Label:
                            id: tripDist
                            text: ''
                            font_name: 'CaviarDreams.ttf'
                            font_size: '14sp'
                            color: 0.1, 0.1, 0.1, 1
                            size_hint_x: 0.6
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size

                    # Duration
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '30dp'
                        spacing: '8dp'
                        Label:
                            text: app.trip_duration_text
                            font_name: 'CaviarDreams_Bold.ttf'
                            font_size: '13sp'
                            color: 0.4, 0.4, 0.4, 1
                            size_hint_x: 0.4
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size
                        Label:
                            id: tripTime
                            text: ''
                            font_name: 'CaviarDreams.ttf'
                            font_size: '14sp'
                            color: 0.1, 0.1, 0.1, 1
                            size_hint_x: 0.6
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size

                    # Fuel
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '30dp'
                        spacing: '8dp'
                        Label:
                            text: app.estimated_fuel_text
                            font_name: 'CaviarDreams_Bold.ttf'
                            font_size: '13sp'
                            color: 0.4, 0.4, 0.4, 1
                            size_hint_x: 0.4
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size
                        Label:
                            id: tripFuel
                            text: ''
                            font_name: 'CaviarDreams.ttf'
                            font_size: '14sp'
                            color: 0.1, 0.1, 0.1, 1
                            size_hint_x: 0.6
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size

                Widget:
                    size_hint_y: None
                    height: '15dp'

                # Three action buttons in a row
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: '60dp'
                    spacing: '8dp'
                    
                    Button:
                        text: app.home_text2
                        font_name: 'CaviarDreams.ttf'
                        font_size: '12sp'
                        background_normal: ''
                        background_color: 0, 0, 0, 0
                        color: 0.4, 0.4, 0.4, 1
                        canvas.before:
                            Color:
                                rgba: 0.92, 0.92, 0.92, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [10, 10, 10, 10]
                        on_release:
                            root.clearCurrent()
                            app.root.current = "Home"
                            root.manager.transition.direction = "down"
                    
                    Button:
                        text: app.view_all_trips_text
                        font_name: 'CaviarDreams.ttf'
                        font_size: '12sp'
                        background_normal: ''
                        background_color: 0, 0, 0, 0
                        color: 0.4, 0.4, 0.4, 1
                        canvas.before:
                            Color:
                                rgba: 0.92, 0.92, 0.92, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [10, 10, 10, 10]
                        on_release:
                            app.root.current = "IndividualTripsPage"
                            root.manager.transition.direction = "left"

                Button:
                    text: app.start_next_trip_text
                    font_name: 'CaviarDreams_Bold.ttf'
                    font_size: '16sp'
                    size_hint_y: None
                    height: '55dp'
                    background_normal: ''
                    background_color: 0, 0, 0, 0
                    color: 1, 1, 1, 1
                    canvas.before:
                        Color:
                            rgba: 0.05, 0.05, 0.05, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [12, 12, 12, 12]
                    on_release:
                        root.clearCurrent()
                        app.root.current = "Destination"
                        root.manager.transition.direction = "down"

                Widget:
                    size_hint_y: None
                    height: '20dp'

<HomeStatsPage>:
    name: "HomeStatsPage"
    FloatLayout:
        canvas.before:
            Color:
                rgba: 0.98, 0.98, 0.98, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # Language Toggle
        Button:
            size_hint: (None, None)
            size: ('53dp', '53dp')
            pos_hint: {'right': 0.95, 'top': 0.97}
            background_normal: ''
            background_color: 1, 1, 1, 1
            text: app.language_button_text
            font_size: '28sp'
            color: 0.2, 0.2, 0.2, 1
            canvas.before:
                Color:
                    rgba: 0.9, 0.9, 0.9, 1
                Ellipse:
                    pos: self.pos
                    size: self.size
            on_release: app.toggle_language()

        # Back Button
        Button:
            text: '←'
            font_name: 'CaviarDreams_Bold.ttf'
            font_size: '28sp'
            size_hint: (None, None)
            size: ('60dp', '60dp')
            pos_hint: {'x': 0.05, 'top': 0.97}
            background_normal: ''
            background_color: 0, 0, 0, 0
            color: 0.2, 0.2, 0.2, 1
            on_release:
                app.root.current = "Home"
                root.manager.transition.direction = "up"

        BoxLayout:
            orientation: 'vertical'
            padding: ['25dp', '85dp', '25dp', '30dp']
            spacing: '18dp'

            # Title
            Label:
                text: app.language and app.translator.get_text('statistics_today')
                font_name: 'CaviarDreams_Bold.ttf'
                font_size: '24sp'
                color: 0.1, 0.1, 0.1, 1
                size_hint_y: 0.1
                halign: 'center'

            # Stats Card
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: 0.75
                padding: ['15dp', '18dp']
                spacing: '10dp'
                canvas.before:
                    Color:
                        rgba: 1, 1, 1, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [15, 15, 15, 15]

                # Number of Trips
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: 0.2
                    spacing: '10dp'
                    Label:
                        text: app.language and app.translator.get_text('number_of_trips') + ':'
                        font_name: 'CaviarDreams_Bold.ttf'
                        font_size: '14sp'
                        color: 0.3, 0.3, 0.3, 1
                        size_hint_x: 0.55
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        id: NumberOfTrips
                        text: ''
                        font_name: 'CaviarDreams.ttf'
                        font_size: '16sp'
                        color: 0.1, 0.1, 0.1, 1
                        size_hint_x: 0.45
                        halign: 'right'
                        valign: 'middle'
                        text_size: self.size

                # Kilometers Driven
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: 0.2
                    spacing: '10dp'
                    Label:
                        text: app.language and app.translator.get_text('kilometers_driven') + ':'
                        font_name: 'CaviarDreams_Bold.ttf'
                        font_size: '14sp'
                        color: 0.3, 0.3, 0.3, 1
                        size_hint_x: 0.55
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        id: MilesDriven
                        text: ''
                        font_name: 'CaviarDreams.ttf'
                        font_size: '16sp'
                        color: 0.1, 0.1, 0.1, 1
                        size_hint_x: 0.45
                        halign: 'right'
                        valign: 'middle'
                        text_size: self.size

                # Estimated Gas
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: 0.2
                    spacing: '10dp'
                    Label:
                        text: app.language and app.translator.get_text('estimated_gas') + ':'
                        font_name: 'CaviarDreams_Bold.ttf'
                        font_size: '14sp'
                        color: 0.3, 0.3, 0.3, 1
                        size_hint_x: 0.55
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        id: EstimatedGas
                        text: ''
                        font_name: 'CaviarDreams.ttf'
                        font_size: '16sp'
                        color: 0.1, 0.1, 0.1, 1
                        size_hint_x: 0.45
                        halign: 'right'
                        valign: 'middle'
                        text_size: self.size

                # Total Time
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: 0.2
                    spacing: '10dp'
                    Label:
                        text: app.language and app.translator.get_text('total_time') + ':'
                        font_name: 'CaviarDreams_Bold.ttf'
                        font_size: '14sp'
                        color: 0.3, 0.3, 0.3, 1
                        size_hint_x: 0.55
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        id: TotalTime
                        text: ''
                        font_name: 'CaviarDreams.ttf'
                        font_size: '16sp'
                        color: 0.1, 0.1, 0.1, 1
                        size_hint_x: 0.45
                        halign: 'right'
                        valign: 'middle'
                        text_size: self.size

                # Time Between
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: 0.2
                    spacing: '10dp'
                    Label:
                        text: app.language and app.translator.get_text('time_between') + ':'
                        font_name: 'CaviarDreams_Bold.ttf'
                        font_size: '14sp'
                        color: 0.3, 0.3, 0.3, 1
                        size_hint_x: 0.55
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        id: TimeBetween
                        text: ''
                        font_name: 'CaviarDreams.ttf'
                        font_size: '16sp'
                        color: 0.1, 0.1, 0.1, 1
                        size_hint_x: 0.45
                        halign: 'right'
                        valign: 'middle'
                        text_size: self.size

            # Toggle Button - View Individual Trips
            Button:
                text: app.language and app.translator.get_text('view_individual_trips')
                font_name: 'CaviarDreams.ttf'
                font_size: '16sp'
                size_hint_y: None
                height: '55dp'
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 0.4, 0.4, 0.4, 1
                canvas.before:
                    Color:
                        rgba: 0.92, 0.92, 0.92, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [12, 12, 12, 12]
                on_release:
                    app.root.current = "IndividualTripsPage"
                    root.manager.transition.direction = "left"

<IndividualTripsPage>:
    name: "IndividualTripsPage"
    FloatLayout:
        canvas.before:
            Color:
                rgba: 0.98, 0.98, 0.98, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # Language Toggle
        Button:
            size_hint: (None, None)
            size: ('53dp', '53dp')
            pos_hint: {'right': 0.95, 'top': 0.97}
            background_normal: ''
            background_color: 1, 1, 1, 1
            text: app.language_button_text
            font_size: '28sp'
            color: 0.2, 0.2, 0.2, 1
            canvas.before:
                Color:
                    rgba: 0.9, 0.9, 0.9, 1
                Ellipse:
                    pos: self.pos
                    size: self.size
            on_release: app.toggle_language()

        # Back Button
        Button:
            text: '←'
            font_name: 'CaviarDreams_Bold.ttf'
            font_size: '28sp'
            size_hint: (None, None)
            size: ('60dp', '60dp')
            pos_hint: {'x': 0.05, 'top': 0.97}
            background_normal: ''
            background_color: 0, 0, 0, 0
            color: 0.2, 0.2, 0.2, 1
            on_release:
                app.root.current = "HomeStatsPage"
                root.manager.transition.direction = "right"

        BoxLayout:
            orientation: 'vertical'
            padding: ['25dp', '85dp', '25dp', '30dp']
            spacing: '12dp'

            # Title
            Label:
                text: app.all_trips_text
                font_name: 'CaviarDreams_Bold.ttf'
                font_size: '24sp'
                color: 0.1, 0.1, 0.1, 1
                size_hint_y: None
                height: '40dp'
                halign: 'center'

            # Toggle buttons for Today vs Past
            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: '50dp'
                spacing: '10dp'
                
                Button:
                    id: today_btn
                    text: app.today_text
                    font_name: 'CaviarDreams_Bold.ttf'
                    font_size: '16sp'
                    background_normal: ''
                    background_color: 0.05, 0.05, 0.05, 1
                    color: 1, 1, 1, 1
                    canvas.before:
                        Color:
                            rgba: self.background_color
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [10, 10, 10, 10]
                    on_release:
                        root.load_todays_trips()
                
                Button:
                    id: past_btn
                    text: app.past_text
                    font_name: 'CaviarDreams_Bold.ttf'
                    font_size: '16sp'
                    background_normal: ''
                    background_color: 0.92, 0.92, 0.92, 1
                    color: 0.4, 0.4, 0.4, 1
                    canvas.before:
                        Color:
                            rgba: self.background_color
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [10, 10, 10, 10]
                    on_release:
                        root.load_past_trips()

            # Scrollable trips container
            ScrollView:
                do_scroll_x: False
                do_scroll_y: True
                scroll_timeout: 250
                scroll_distance: 10
                effect_cls: 'ScrollEffect'
                BoxLayout:
                    id: trips_container
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: '10dp'
                    padding: ['5dp', '10dp', '5dp', '10dp']

<TripDetailPage>:
    name: "TripDetailPage"
    FloatLayout:
        canvas.before:
            Color:
                rgba: 0.98, 0.98, 0.98, 1
            Rectangle:
